  file_change {
    absolute_path_uri: "file:///src/components/ProfileView.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \'react\';\nimport { User, Award, Shield, Settings, Bell, HelpCircle, Flame, Check, CheckCircle2 } from \'lucide-react\';\nimport { UserProfile } from \'../types\';\n\ninterface ProfileViewProps {\n  profile: UserProfile;\n  setProfile: React.Dispatch<React.SetStateAction<UserProfile>>;\n}\n\nexport default function ProfileView({ profile, setProfile }: ProfileViewProps) {\n  const fitnessGoals = [\'Beginners\', \'Weight Loss\', \'Muscle Building\', \'Athletic\'];\n\n  const handleToggleSetting = (key: keyof UserProfile[\'settings\']) => {\n    setProfile((prev) => ({\n      ...prev,\n      settings: {\n        ...prev.settings,\n        [key]: !prev.settings[key]\n      }\n    }));\n  };\n\n  const handleSelectGoal = (goal: string) => {\n    setProfile((prev) => ({\n      ...prev,\n      fitnessGoal: goal\n    }));\n  };\n\n  // Convert settings labels for easy scanning\n  const settingItems = [\n    { key: \'restTimerAlerts\', label: \'Rest Timer Alerts\', desc: \'Alert when workout rest interval elapses.\' },\n    { key: \'videoTutorials\', label: \'Instructional Videos Autoplay\', desc: \'Pre-load YouTube clips during workouts.\' },\n    { key: \'aiCoachReminders\', label: \'AI Health Coaching Reminders\', desc: \'Push reminders for daily streak targets.\' },\n    { key: \'weeklyCheckIn\', label: \'Weekly Performance Summaries\', desc: \'E-mail custom progress breakdowns.\' }\n  ] as const;\n\n  return (\n    <div id=\"profile-view\" className=\"space-y-6 max-w-4xl mx-auto pb-12\">\n      <div className=\"text-center sm:text-left\">\n        <h2 className=\"text-3xl font-display tracking-wider text-white\">ATHLETE BIO & SETTINGS</h2>\n        <p className=\"text-xs text-gray-400 mt-1 uppercase font-mono tracking-widest\">Tune your personal goal paths and workout configurations</p>\n      </div>\n\n      {/* Main Profile Header Avatar Card & Level progress */}\n      <div className=\"bg-[#141414] border border-[#222] rounded-2xl p-6 flex flex-col md:flex-row md:items-center justify-between gap-6\">\n        <div className=\"flex items-center gap-5\">\n          {/* Avatar frame */}\n          <div className=\"w-18 h-18 rounded-full bg-gradient-to-tr from-[#E24B4A] to-red-800 text-white font-display text-2xl flex items-center justify-center shadow-lg shadow-[#E24B4A]/25 ring-4 ring-[#242424] shrink-0\">\n            FW\n          </div>\n          <div>\n            <div className=\"flex flex-wrap items-center gap-2\">\n              <h3 className=\"text-2xl font-bold text-white tracking-wide\">{profile.name}</h3>\n              <span className=\"text-[10px] uppercase font-mono tracking-wider font-extrabold bg-[#E24B4A]/10 border border-[#E24B4A]/25 text-[#E24B4A] py-1 px-3 rounded-full\">\n                {profile.fitnessGoal.toUpperCase()}\n              </span>\n            </div>\n            \n            <p className=\"text-xs text-gray-400 flex items-center gap-1.5 mt-1 font-mono\">\n              <Award className=\"w-3.5 h-3.5 text-[#E24B4A]\" /> LEVEL 7 &bull; INTERMEDIATE ATHLETE\n            </p>\n          </div>\n        </div>\n\n        {/* XP Tracking bar right side */}\n        <div className=\"w-full md:max-w-xs space-y-2 border-t md:border-t-0 border-[#242424] pt-4 md:pt-0\">\n          <div className=\"flex justify-between items-center text-xs\">\n            <span className=\"font-mono text-gray-400 text-[10px] tracking-wider uppercase font-extrabold\">XP progress</span>\n            <span className=\"font-mono text-white font-semibold\">{profile.xp} / {profile.xpNext} XP</span>\n          </div>\n          {/* Progress outer track */}\n          <div className=\"w-full h-3.5 rounded-full bg-[#242424] overflow-hidden border border-[#222]\">\n            <div \n              id=\"profile-xp-progress\"\n              className=\"h-full bg-gradient-to-r from-[#E24B4A] to-red-500 rounded-full transition-all duration-500\"\n              style={{ width: `${(profile.xp / profile.xpNext) * 100}%` }}\n            />\n          </div>\n          <span className=\"text-[10px] text-gray-500 block text-right\">\n            Level up to unlock advanced Olympic routines\n          </span>\n        </div>\n      </div>\n\n      {/* Grid statistics highlights */}\n      <div className=\"grid grid-cols-3 gap-3\">\n        <div className=\"bg-[#141414] border border-[#222] rounded-2xl p-4 text-center\">\n          <span className=\"text-[10px] text-gray-500 uppercase font-mono tracking-wider block\">WORKOUTS DONE</span>\n          <span className=\"text-white text-xl sm:text-2xl font-bold block mt-1\">{profile.workoutsCompleted}</span>\n        </div>\n        <div className=\"bg-[#141414] border border-[#222] rounded-2xl p-4 text-center\">\n          <span className=\"text-[10px] text-gray-500 uppercase font-mono tracking-wider block\">DIET / WEIGHT</span>\n          <span className=\"text-white text-xl sm:text-2xl font-bold block mt-1\">{profile.weightProgress}</span>\n        </div>\n        <div className=\"bg-[#141414] border border-[#222] rounded-2xl p-4 text-center\">\n          <span className=\"text-[10px] text-gray-500 uppercase font-mono tracking-wider block\">STREAK DAYS</span>\n          <span className=\"text-[#E24B4A] text-xl sm:text-2xl font-bold block mt-1\">\360\237\224\245 {profile.streak}</span>\n        </div>\n      </div>\n\n      {/* Fitness goal active selector */}\n      <div className=\"bg-[#141414] border border-[#222] rounded-2xl p-5 md:p-6 space-y-4\">\n        <h4 className=\"text-sm font-bold text-white tracking-widest uppercase font-mono\">\n          TARGET FITNESS GOAL\n        </h4>\n        <p className=\"text-xs text-gray-400\">\n          This dynamically informs the AI Coach\'s feedback priority, exercise weight setups, and target progression patterns.\n        </p>\n\n        <div className=\"grid grid-cols-2 md:grid-cols-4 gap-3\">\n          {fitnessGoals.map((g) => {\n            const isSelected = profile.fitnessGoal === g;\n            return (\n              <button\n                id={`btn-select-goal-${g}`}\n                key={g}\n                onClick={() => handleSelectGoal(g)}\n                className={`flex items-center justify-between p-3.5 rounded-xl border font-bold text-xs uppercase tracking-wider transition duration-200 cursor-pointer ${\n                  isSelected \n                    ? \'bg-[#E24B4A] border-[#E24B4A] text-white shadow shadow-[#E24B4A]/25 scale-102\'\n                    : \'bg-[#222] border-[#222] text-gray-400 hover:text-white hover:border-[#333]\'\n                }`}\n              >\n                <span>{g}</span>\n                {isSelected && <CheckSquareIcon />}\n              </button>\n            );\n          })}\n        </div>\n      </div>\n\n      {/* App configuration options toggles */}\n      <div className=\"bg-[#141414] border border-[#222] rounded-2xl p-5 md:p-6 space-y-4\">\n        <h4 className=\"text-sm font-bold text-white tracking-widest uppercase font-mono\">\n          COACHING SETTINGS & PREFERENCES\n        </h4>\n\n        <div className=\"divide-y divide-[#242424]\">\n          {settingItems.map((item) => {\n            const isChecked = profile.settings[item.key];\n            return (\n              <div \n                id={`setting-row-${item.key}`}\n                key={item.key}\n                onClick={() => handleToggleSetting(item.key)}\n                className=\"flex items-center justify-between py-4.5 cursor-pointer first:pt-0 last:pb-0\"\n              >\n                <div className=\"space-y-1\">\n                  <span className=\"text-sm font-semibold text-white block\">\n                    {item.label}\n                  </span>\n                  <p className=\"text-xs text-gray-500 leading-snug\">\n                    {item.desc}\n                  </p>\n                </div>\n\n                {/* Switch button tracker */}\n                <button\n                  id={`btn-setting-toggle-${item.key}`}\n                  type=\"button\"\n                  className={`w-11 h-6 rounded-full p-1 relative flex items-center transition ease-in-out duration-300 ${\n                    isChecked ? \'bg-[#E24B4A]\' : \'bg-[#242424]\'\n                  }`}\n                >\n                  <span \n                    className={`inline-block w-4.5 h-4.5 rounded-full bg-white shadow-md transform transition duration-300 ${\n                      isChecked ? \'translate-x-5\' : \'translate-x-0\'\n                    }`} \n                  />\n                </button>\n              </div>\n            );\n          })}\n        </div>\n      </div>\n    </div>\n  );\n}\n\n// Small helper Check SVG\nfunction CheckSquareIcon() {\n  return (\n    <div className=\"w-4 h-4 rounded bg-white/20 flex items-center justify-center\">\n      <Check className=\"w-3 h-3 text-white stroke-[3px]\" />\n    </div>\n  );\n}\n"
