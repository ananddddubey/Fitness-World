    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700;800&family=Bebas+Neue&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Barlow\", ui-sans-serif, system-ui, sans-serif;\n  --font-display: \"Bebas Neue\", sans-serif;\n  --color-accent-red: #e24b4a;\n}\n\nbody {\n  background-color: #0f0f0f;\n  color: #ffffff;\n  font-family: var(--font-sans);\n}\n\n/* Glass card styling matching Immersive UI spec */\n.glass-card {\n  background: rgba(26, 26, 26, 0.75);\n  backdrop-filter: blur(12px);\n  -webkit-backdrop-filter: blur(12px);\n  border: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n/* Gradient colors for buttons, levels, progress meters */\n.red-gradient {\n  background: linear-gradient(135deg, #e24b4a 0%, #992121 100%);\n}\n\n/* Premium Crimson Accent Glow */\n.accent-glow {\n  box-shadow: 0 0 15px rgba(226, 75, 74, 0.4);\n}\n\n/* Active navigation highlighted states */\n.sidebar-item-active {\n  background: rgba(226, 75, 74, 0.1);\n  color: #e24b4a;\n  border-right: 3px solid #e24b4a;\n}\n\n/* Slide up animation for bottom detail drawers */\n@keyframes slideUp {\n  from {\n    transform: translateY(100%);\n    opacity: 0;\n  }\n  to {\n    transform: translateY(0);\n    opacity: 1;\n  }\n}\n\n.animate-slide-up {\n  animation: slideUp 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n}\n\n/* Elegant responsive appearance transition */\n@keyframes fadeIn {\n  from {\n    opacity: 0;\n    transform: translateY(6px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.animate-fade-in {\n  animation: fadeIn 0.45s ease-out forwards;\n}\n\n/* Dark mode premium scrollbar rules */\n::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n::-webkit-scrollbar-track {\n  background: #0f0f0f;\n}\n::-webkit-scrollbar-thumb {\n  background: rgba(255, 255, 255, 0.08);\n  border-radius: 4px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(226, 75, 74, 0.4);\n}\n"
