    instruction: "Update TrainView to align with Immersive UI styles using glass-cards, italic Bebas headings, hover transitions, and glow dots."
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div id=\"train-view\" className=\"space-y-6 max-w-4xl mx-auto pb-12\">\n      <div className=\"text-center sm:text-left\">\n        <h2 className=\"text-3xl font-display tracking-wider text-white\">GOAL-BASED TRAINING HUBS</h2>\n        <p className=\"text-xs text-gray-400 mt-1 uppercase font-mono tracking-widest\">Select your core training goal to unlock specific exercises</p>\n      </div>\n\n      {/* Goal Selector Horizontal Tabs */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3\">\n        {goals.map((goal) => {\n          const Icon = goal.icon;\n          const isActive = activeGoal === goal.id;\n          return (\n            <button\n              id={`tab-goal-${goal.id}`}\n              key={goal.id}\n              onClick={() => setActiveGoal(goal.id)}\n              className={`text-left p-4.5 rounded-2xl border transition-all duration-300 relative overflow-hidden group hover:-translate-y-0.5 cursor-pointer ${\n                isActive \n                  ? \'bg-[#E24B4A]/10 border-[#E24B4A] shadow shadow-[#E24B4A]/10\' \n                  : \'bg-[#141414] border-[#222] hover:border-[#333]\'\n              }`}\n            >\n              {/* Backglow element */}\n              {isActive && (\n                <div className=\"absolute top-0 right-0 w-24 h-24 bg-[#E24B4A]/5 rounded-full blur-xl pointer-events-none\" />\n              )}\n              \n              <div className=\"flex items-center gap-3\">\n                <div className={`p-2 rounded-xl transition-all duration-300 ${\n                  isActive ? \'bg-[#E24B4A] text-white\' : \'bg-[#222] text-gray-500 group-hover:text-gray-300\'\n                }`}>\n                  <Icon className=\"w-5 h-5 animate-pulse\" />\n                </div>\n                <div>\n                  <h4 className={`text-sm font-bold tracking-wide font-sans ${isActive ? \'text-white\' : \'text-gray-400\'}`}>\n                    {goal.label}\n                  </h4>\n                  <p className=\"text-[11px] text-gray-500 mt-0.5 leading-snug\">\n                    {goal.desc}\n                  </p>\n                </div>\n              </div>\n            </button>\n          );\n        })}\n      </div>\n\n      {/* Workout Exercise Deck list */}\n      <div className=\"space-y-4\">\n        <h3 className=\"text-xs font-mono tracking-widest text-[#E24B4A] font-bold uppercase\">\n          RECOMMENDED PROTOCOLS ({filteredExercises.length})\n        </h3>\n\n        <div className=\"grid grid-cols-1 gap-4\">\n          {filteredExercises.map((ex) => {\n            const activeSets = completedSets[ex.id] || Array(ex.sets).fill(false);\n            const completedCount = activeSets.filter(Boolean).length;\n            const isFinished = completedCount === ex.sets;\n\n            return (\n              <div\n                id={`exercise-card-${ex.id}`}\n                key={ex.id}\n                onClick={() => onSelectExercise(ex)}\n                className={`group bg-[#141414] border hover:border-gray-500 rounded-2xl p-5 sm:p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-5 transition duration-300 shadow cursor-pointer ${\n                  isFinished ? \'border-green-500/30 bg-green-500/[0.01]\' : \'border-[#222]\'\n                }`}\n              >\n                {/* Left side: Exercise Metadata */}\n                <div className=\"flex-1 space-y-3\">\n                  <div className=\"flex flex-wrap items-center gap-2\">\n                    <span className=\"text-[10px] uppercase font-mono tracking-widest font-extrabold text-[#E24B4A] bg-[#E24B4A]/10 border border-[#E24B4A]/25 px-2.5 py-0.5 rounded-full\">\n                      {ex.muscleGroup}\n                    </span>\n                    <span className=\"text-[10px] font-mono tracking-wider text-gray-400\">\n                      REST: {ex.rest}\n                    </span>\n                  </div>\n\n                  <h4 className=\"text-xl font-bold font-sans text-white group-hover:text-[#E24B4A] transition-colors leading-none\">\n                    {ex.name}\n                  </h4>\n\n                  <p className=\"text-xs text-gray-400 max-w-xl\">\n                    Target: <strong className=\"text-[#E24B4A]\">{ex.sets} sets \303\227 {ex.reps}</strong>. \n                    <span className=\"text-gray-500 inline ml-1.5\">Focus on {ex.defaultTips[0].toLowerCase()}</span>\n                  </p>\n                </div>\n\n                {/* Right side: Set Completion dots & Guide Action */}\n                <div \n                  className=\"flex flex-col sm:flex-row items-stretch sm:items-center gap-4 pt-4 sm:pt-0 border-t sm:border-t-0 border-[#242424]\"\n                  onClick={(e) => e.stopPropagation()}\n                >\n                  {/* Set Tracker dots */}\n                  <div className=\"flex flex-col items-center sm:items-end gap-1.5\">\n                    <span className=\"text-[9px] font-mono uppercase tracking-widest text-gray-500 font-bold\">\n                      COMPLETION SET-LIST\n                    </span>\n                    <div className=\"flex items-center gap-1.5\">\n                      {activeSets.map((isDone, index) => (\n                        <button\n                          id={`btn-train-set-dot-${ex.id}-${index}`}\n                          key={index}\n                          onClick={() => toggleSetCompleted(ex.id, index)}\n                          className={`w-7.5 h-7.5 rounded-full border text-[10px] font-bold flex items-center justify-center transition cursor-pointer hover:scale-110 ${\n                            isDone \n                              ? \'bg-[#E24B4A] border-[#E24B4A] text-white shadow shadow-[#E24B4A]/25\' \n                              : \'border-[#333] hover:border-gray-500 text-gray-400 bg-[#222]\'\n                          }`}\n                          title={`Toggle Set ${index + 1}`}\n                        >\n                          {isDone ? <Check className=\"w-3.5 h-3.5\" /> : index + 1}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  <button\n                    id={`btn-open-detail-${ex.id}`}\n                    onClick={() => onSelectExercise(ex)}\n                    className=\"h-10 px-4 rounded-xl bg-[#222] hover:bg-neutral-800 text-xs font-bold uppercase tracking-wider text-gray-300 hover:text-white flex items-center justify-center gap-2 border border-[#2d2d2d] hover:border-gray-500 transition cursor-pointer\"\n                  >\n                    <span>Guide</span>\n                    <ArrowRight className=\"w-3.5 h-3.5 text-[#E24B4A] group-hover:translate-x-1 transition-transform\" />\n                  </button>\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>\n    </div>"
        replacement_content: "  return (\n    <div id=\"train-view\" className=\"space-y-6 max-w-4xl mx-auto pb-12 animate-fade-in\">\n      <div className=\"text-center sm:text-left\">\n        <h2 className=\"text-3xl font-display tracking-wider text-white italic\">GOAL-BASED TRAINING HUBS</h2>\n        <p className=\"text-xs text-white/40 mt-1 uppercase font-mono tracking-widest font-semibold\">Select your core training goal to unlock specific exercises</p>\n      </div>\n\n      {/* Goal Selector Horizontal Tabs */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3\">\n        {goals.map((goal) => {\n          const Icon = goal.icon;\n          const isActive = activeGoal === goal.id;\n          return (\n            <button\n              id={`tab-goal-${goal.id}`}\n              key={goal.id}\n              onClick={() => setActiveGoal(goal.id)}\n              className={`text-left p-4.5 rounded-xl border transition-all duration-300 relative overflow-hidden group hover:-translate-y-0.5 cursor-pointer ${\n                isActive \n                  ? \'bg-[#E24B4A]/10 border-[#E24B4A] shadow shadow-[#E24B4A]/10\' \n                  : \'glass-card border-white/5 hover:border-white/10\'\n              }`}\n            >\n              {/* Backglow element */}\n              {isActive && (\n                <div className=\"absolute top-0 right-0 w-24 h-24 bg-[#E24B4A]/5 rounded-full blur-xl pointer-events-none\" />\n              )}\n              \n              <div className=\"flex items-center gap-3\">\n                <div className={`p-2 rounded-lg transition-all duration-300 ${\n                  isActive ? \'bg-[#E24B4A] text-white\' : \'bg-white/5 text-white/40 group-hover:text-white/80\'\n                }`}>\n                  <Icon className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className={`text-xs font-bold font-mono tracking-widest ${isActive ? \'text-[#E24B4A]\' : \'text-white/70\'}`}>\n                    {goal.label}\n                  </h4>\n                  <p className=\"text-[10px] text-white/40 mt-0.5 leading-snug\">\n                    {goal.desc}\n                  </p>\n                </div>\n              </div>\n            </button>\n          );\n        })}\n      </div>\n\n      {/* Workout Exercise Deck list */}\n      <div className=\"space-y-4\">\n        <h3 className=\"font-display text-xl flex items-center text-white font-bold select-none tracking-wider uppercase\">\n          RECOMMENDED PROTOCOLS ({filteredExercises.length}) <span className=\"ml-4 h-px flex-1 bg-white/10\"></span>\n        </h3>\n\n        <div className=\"grid grid-cols-1 gap-4\">\n          {filteredExercises.map((ex) => {\n            const activeSets = completedSets[ex.id] || Array(ex.sets).fill(false);\n            const completedCount = activeSets.filter(Boolean).length;\n            const isFinished = completedCount === ex.sets;\n\n            return (\n              <div\n                id={`exercise-card-${ex.id}`}\n                key={ex.id}\n                onClick={() => onSelectExercise(ex)}\n                className={`group glass-card border-white/5 hover:border-white/15 rounded-xl p-5 sm:p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-5 transition duration-300 cursor-pointer ${\n                  isFinished ? \'border-l-4 border-l-green-500/80 bg-green-500/[0.01]\' : \'border-l-4 border-l-[#E24B4A]\'\n                }`}\n              >\n                {/* Left side: Exercise Metadata */}\n                <div className=\"flex-1 space-y-3\">\n                  <div className=\"flex flex-wrap items-center gap-2\">\n                    <span className=\"text-[9px] uppercase font-mono tracking-widest font-extrabold text-[#E24B4A] bg-[#E24B4A]/10 border border-[#E24B4A]/25 px-2 rounded-full\">\n                      {ex.muscleGroup}\n                    </span>\n                    <span className=\"text-[9px] font-mono tracking-wider text-white/40 font-semibold\">\n                      REST: {ex.rest}\n                    </span>\n                  </div>\n\n                  <h4 className=\"text-xl font-bold text-white group-hover:text-[#E24B4A] transition-colors leading-none\">\n                    {ex.name}\n                  </h4>\n\n                  <p className=\"text-xs text-white/50 max-w-xl leading-relaxed\">\n                    Target: <strong className=\"text-white\">{ex.sets} sets \303\227 {ex.reps}</strong>. \n                    <span className=\"text-white/40 inline ml-1.5 font-mono\">Focus: {ex.defaultTips[0].toLowerCase()}</span>\n                  </p>\n                </div>\n\n                {/* Right side: Set Completion dots & Guide Action */}\n                <div \n                  className=\"flex flex-col sm:flex-row items-stretch sm:items-center gap-4 pt-4 sm:pt-0 border-t sm:border-t-0 border-white/5\"\n                  onClick={(e) => e.stopPropagation()}\n                >\n                  {/* Set Tracker dots */}\n                  <div className=\"flex flex-col items-center sm:items-end gap-1.5\">\n                    <span className=\"text-[9px] font-mono uppercase tracking-widest text-white/40 font-extrabold\">\n                      COMPLETION SET-LIST\n                    </span>\n                    <div className=\"flex items-center gap-1.5\">\n                      {activeSets.map((isDone, index) => (\n                        <button\n                          id={`btn-train-set-dot-${ex.id}-${index}`}\n                          key={index}\n                          onClick={() => toggleSetCompleted(ex.id, index)}\n                          className={`w-7.5 h-7.5 rounded-full border text-[10px] font-mono font-bold flex items-center justify-center transition cursor-pointer hover:scale-110 ${\n                            isDone \n                              ? \'bg-[#E24B4A] border-[#E24B4A] text-white shadow shadow-[#E24B4A]/25 accent-