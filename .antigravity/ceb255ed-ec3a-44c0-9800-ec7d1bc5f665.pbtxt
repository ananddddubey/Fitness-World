    replacement_infos {
      original_chunk {
        target_content: "export const WEEKLY_PROGRAM: WorkoutDay[] = [\n  {\n    day: \'Monday\',\n    title: \'Upper Body Push\',\n    exercises: [\n      { name: \'Bench Press\', target: \'4 sets \303\227 10 reps (Chest & Triceps)\' },\n      { name: \'Incline Dumbbell Press\', target: \'3 sets \303\227 12 reps (Upper Chest)\' },\n      { name: \'Overhead Press (OHP)\', target: \'3 sets \303\227 10 reps (Shoulders)\' },\n      { name: \'Tricep Rope Pushdown\', target: \'3 sets \303\227 15 reps (Triceps)\' }\n    ]\n  },\n  {\n    day: \'Tuesday\',\n    title: \'Lower Body Focus\',\n    exercises: [\n      { name: \'Barbell Squat\', target: \'5 sets \303\227 5 reps (Quads & Glutes)\' },\n      { name: \'Leg Press\', target: \'4 sets \303\227 12 reps (Hamstrings & Quads)\' },\n      { name: \'Walking Lunges\', target: \'3 sets \303\227 16 steps (Hip Stability)\' },\n      { name: \'Calf Raises\', target: \'4 sets \303\227 20 reps (Calves)\' }\n    ]\n  },\n  {\n    day: \'Wednesday\',\n    title: \'Active Recovery & Mobility\',\n    exercises: [\n      { name: \'Light Cardio\', target: \'20 mins low intensity (HR 120-130)\' },\n      { name: \'Foam Rolling\', target: \'10 mins total-body release\' },\n      { name: \'Dynamic Mobility Work\', target: \'15 mins hips & thoracic spine\' }\n    ]\n  },\n  {\n    day: \'Thursday\',\n    title: \'Upper Body Pull\',\n    exercises: [\n      { name: \'Pull-Ups / Lat Pulldown\', target: \'4 sets \303\227 8 reps (Lats & Back)\' },\n      { name: \'Barbell Row\', target: \'4 sets \303\227 10 reps (Mid-Back)\' },\n      { name: \'Face Pulls\', target: \'3 sets \303\227 15 reps (Rear Delts & Rotators)\' },\n      { name: \'Incline Bicep Curls\', target: \'3 sets \303\227 12 reps (Biceps)\' }\n    ]\n  },\n  {\n    day: \'Friday\',\n    title: \'Full Body Power\',\n    exercises: [\n      { name: \'Deadlift\', target: \'4 sets \303\227 5 reps (Posterior Chain)\' },\n      { name: \'Power Clean / Hang Clean\', target: \'3 sets \303\227 4 reps (Explosive Hips)\' },\n      { name: \'Box Jump\', target: \'3 sets \303\227 8 reps (Reactive Leg Power)\' },\n      { name: \'Core Circuit\', target: \'3 rounds (Plank, Woodchops, Leg Raises)\' }\n    ]\n  },\n  {\n    day: \'Saturday\',\n    title: \'Metabolic Conditioning (HIIT)\',\n    exercises: [\n      { name: \'HIIT Treadmill / Row Sprint\', target: \'20 mins (30s sprint / 30s rest)\' },\n      { name: \'Battle Ropes Slam\', target: \'4 sets \303\227 40s (Full Body Cardiorespiratory)\' },\n      { name: \'Kettlebell Swings\', target: \'4 sets \303\227 20 reps (Power Endurance)\' }\n    ]\n  },\n  {\n    day: \'Sunday\',\n    title: \'Rest & Deep Rejuvenation\',\n    exercises: [\n      { name: \'Rest Day\', target: \'Complete physical reset. Hydrate and eat well.\' }\n    ]\n  }\n];\n\nexport const INITIAL_PROFILE: UserProfile = {\n  name: \'Fitness Warrior\',\n  level: 7,\n  xp: 1360,\n  xpNext: 2000,\n  workoutsCompleted: 34,\n  streak: 21,\n  weightProgress: \'-8kg Overall\',\n  fitnessGoal: \'Muscle Building\',\n  settings: {\n    restTimerAlerts: true,\n    videoTutorials: true,\n    aiCoachReminders: true,\n    weeklyCheckIn: false\n  }\n};"
        replacement_content: "export const WEEKLY_PROGRAMS: Record<string, WorkoutDay[]> = {\n  \'Beginners\': [\n    {\n      day: \'Monday\',\n      title: \'Form Activation & Lower Body\',\n      exercises: [\n        { name: \'Goblet Squat\', target: \'3 sets \303\227 12 reps (Focus: depth & vertical torso)\' },\n        { name: \'Inverted Rows\', target: \'3 sets \303\227 10 reps (Focus: back activation)\' },\n        { name: \'Push-Ups (or Inclined)\', target: \'3 sets \303\227 10 reps (Focus: control & core alignment)\' },\n        { name: \'Bird-Dogs Stability\', target: \'3 sets \303\227 12 reps (Focus: neutral spine)\' }\n      ]\n    },\n    {\n      day: \'Tuesday\',\n      title: \'Active Restoration & Walks\',\n      exercises: [\n        { name: \'Low Intensity Outdoor Walk\', target: \'30 mins active cardiovascular stride\' },\n        { name: \'Full Body Mobility Stretches\', target: \'15 mins join-relief and chest opener stretches\' }\n      ]\n    },\n    {\n      day: \'Wednesday\',\n      title: \'Form Activation & Upper Body Focus\',\n      exercises: [\n        { name: \'Dumbbell Romanian Deadlift\', target: \'3 sets \303\227 10 reps (Focus: hip hinging pattern)\' },\n        { name: \'Seated Dumbbell Overhead Press\', target: \'3 sets \303\227 10 reps (Focus: vertical drive & posture)\' },\n        { name: \'Lat Pulldowns\', target: \'3 sets \303\227 12 reps (Focus: shoulder blade pull down)\' },\n        { name: \'Bodyweight Glute Bridges\', target: \'3 sets \303\227 15 reps (Focus: squeeze at the top)\' }\n      ]\n    },\n    {\n      day: \'Thursday\',\n      title: \'Active Recovery & Core Stabilization\',\n      exercises: [\n        { name: \'Low-Impact Aerobic Cardio\', target: \'20 mins (Stationary cycle or elliptical, Zone 2)\' },\n        { name: \'Plank Holds\', target: \'3 sets \303\227 45s (Focus: solid abs engagement)\' },\n        { name: \'Thoracic Spine Openers\', target: \'10 mins desk posture relief stretches\' }\n      ]\