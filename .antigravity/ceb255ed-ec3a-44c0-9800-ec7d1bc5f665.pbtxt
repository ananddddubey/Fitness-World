  file_change {
    absolute_path_uri: "file:///src/components/ProgramView.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \'react\';\nimport { Calendar, ChevronDown, ChevronUp, Clock, Dumbbell, Sparkles } from \'lucide-react\';\nimport { WorkoutDay } from \'../types\';\n\ninterface ProgramViewProps {\n  weeklyProgram: WorkoutDay[];\n}\n\nexport default function ProgramView({ weeklyProgram }: ProgramViewProps) {\n  // Derive current day to expand it on initial mount\n  const daysOfWeek = [\'Sunday\', \'Monday\', \'Tuesday\', \'Wednesday\', \'Thursday\', \'Friday\', \'Saturday\'];\n  const currentDayName = daysOfWeek[new Date().getDay()];\n\n  const [expandedDay, setExpandedDay] = useState<string | null>(currentDayName);\n\n  const toggleDay = (day: string) => {\n    setExpandedDay(expandedDay === day ? null : day);\n  };\n\n  return (\n    <div id=\"program-view\" className=\"space-y-6 max-w-4xl mx-auto pb-12\">\n      <div className=\"text-center sm:text-left\">\n        <h2 className=\"text-3xl font-display tracking-wider text-white\">8-WEEK ELITE HYBRID PROGRAM</h2>\n        <p className=\"text-xs text-gray-400 mt-1 uppercase font-mono tracking-widest\">Designed for maximum strength, lean mass, and athletic speed</p>\n      </div>\n\n      {/* Program Introductory Header Card */}\n      <div className=\"bg-gradient-to-br from-[#121212] to-[#1d1a1a] border border-[#2d2d2d] rounded-2xl p-6 flex flex-col sm:flex-row gap-5 items-center justify-between\">\n        <div className=\"space-y-2\">\n          <div className=\"inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-[#E24B4A]/10 border border-[#E24B4A]/25 text-[#E24B4A] text-[10px] font-mono font-bold uppercase\">\n            <Sparkles className=\"w-3.5 h-3.5\" /> PROGRAM FOCUS\n          </div>\n          <h3 className=\"text-xl font-bold text-white tracking-wide\">PHASE 1: ACUMEN STRENGTH & ENDURANE</h3>\n          <p className=\"text-xs text-gray-400 max-w-xl leading-relaxed\">\n            Train 5-6 days per week. Prioritize progressive overload (adding load, reps, or lowering rest times) weekly. Track set completion dots inside your active training deck.\n          </p>\n        </div>\n        <div className=\"bg-[#242424] px-5 py-3 rounded-xl border border-[#2d2d2d] text-center shrink-0 w-full sm:w-auto\">\n          <span className=\"text-[10px] text-gray-500 font-mono block\">COMPLETION RATING</span>\n          <span className=\"text-[#E24B4A] text-2xl font-display tracking-widest block font-bold mt-1\">WEEK 3 / 8</span>\n        </div>\n      </div>\n\n      {/* Accordion List for Monday - Sunday */}\n      <div className=\"space-y-3 font-sans\">\n        {weeklyProgram.map((item) => {\n          const isToday = item.day === currentDayName;\n          const isExpanded = expandedDay === item.day;\n\n          return (\n            <div\n              id={`program-accordion-day-${item.day}`}\n              key={item.day}\n              className={`border rounded-2xl overflow-hidden transition-all duration-300 ${\n                isToday \n                  ? \'border-[#E24B4A] shadow shadow-[#E24B4A]/5\' \n                  : \'border-[#222] hover:border-[#333]\'\n              }`}\n            >\n              {/* Accordion Trigger Header Button */}\n              <button\n                id={`btn-toggle-day-${item.day}`}\n                onClick={() => toggleDay(item.day)}\n                className={`w-full flex items-center justify-between px-5 py-4.5 text-left transition relative cursor-pointer ${\n                  isExpanded ? \'bg-[#1a1a1a]\' : \'bg-[#121212] hover:bg-[#161616]\'\n                }`}\n              >\n                <div className=\"flex items-center gap-4\">\n                  {/* Date dot marker */}\n                  <div className={`w-10 h-10 rounded-xl flex items-center justify-center font-bold text-xs uppercase tracking-wider font-mono ${\n                    isToday\n                      ? \'bg-[#E24B4A] text-white shadow-md shadow-[#E24B4A]/20\'\n                      : \'bg-[#222] text-gray-400\'\n                  }`}>\n                    {item.day.slice(0, 3)}\n                  </div>\n                  \n                  <div>\n                    <div className=\"flex items-center gap-2\">\n                      <h4 className=\"text-sm font-extrabold text-white uppercase tracking-wider\">\n                        {item.day}\n                      </h4>\n                      {isToday && (\n                        <span className=\"text-[9px] font-mono uppercase bg-[#E24B4A]/15 border border-[#E24B4A]/30 text-[#E24B4A] py-0.5 px-2 rounded-full font-bold\">\n                          TODAY\n                        </span>\n                      )}\n                    </div>\n                    <p className=\"text-xs text-gray-400 font-light mt-0.5\">\n                      {item.title}\n                    </p>\n                  </div>\n                </div>\n\n                <div className=\"flex items-center gap-2\">\n                  <span className=\"text-xs font-mono font-bold text-gray-500 mr-2 uppercase\">\n                    {item.exercises.length} {item.exercises.length === 1 ? \'Focus\' : \'Exercises\'}\n                  </span>\n                  {isExpanded ? (\n                    <ChevronUp className=\"w-5 h-5 text-gray-400\" />\n                  ) : (\n                    <ChevronDown className=\"w-5 h-5 text-gray-400\" />\n                  )}\n                </div>\n              </button>\n\n              {/* Collapsible content pane */}\n              {isExpanded && (\n                <div \n                  id={`program-expanded-pane-${item.day}`}\n                  className=\"bg-[#141414]/90 p-5 border-t border-[#222] space-y-4 animate-slide-up\"\n                >\n                  <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3.5\">\n                    {item.exercises.map((ex, exIdx) => (\n                      <div\n                        key={exIdx}\n                        className=\"bg-[#1d1d1d] border border-[#2d2d2d] hover:border-[#3d3d3d] p-4.5 rounded-xl flex items-start gap-3.5 transition duration-200\"\n                      >\n                        <div className=\"w-7 h-7 rounded-lg bg-[#E24B4A]/10 border border-[#E24B4A]/20 flex items-center justify-center shrink-0\">\n                          <Dumbbell className=\"w-4 h-4 text-[#E24B4A]\" />\n                        </div>\n                        <div>\n                          <h5 className=\"text-sm font-bold text-white tracking-wide\">{ex.name}</h5>\n                          <p className=\"text-xs text-[#E24B4A] font-mono tracking-wide mt-1\">\n                            {ex.target}\n                          </p>\n                        </div>\n                      </div>\n                    ))}\n                  </div>\n\n                  {/* Program Day action advice */}\n                  <div className=\"pt-2 flex items-center gap-3 border-t border-[#222] justify-between text-xs text-gray-500\">\n                    <span className=\"block flex items-center gap-1.5 uppercase font-mono tracking-wider\">\n                      <Clock className=\"w-4 h-4 text-gray-400\" /> Average length: 50-65 mins\n                    </span>\n                    <span className=\"text-[#E24B4A] block font-mono\">\n                      * Squeeze on isometric contractions\n                    </span>\n                  </div>\n                </div>\n              )}\n            </div>\n          );\n        })}\n      </div>\n    </div>\n  );\n}\n"
    }
